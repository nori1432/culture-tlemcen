# ─── Required in production ───────────────────────────────────────────────────

# Cloud MySQL connection string.
# Supported providers: PlanetScale, Railway, Aiven, TiDB Cloud
# Format: mysql+pymysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql+pymysql://user:password@host:3306/tlemcen_tour

# Base URL where place images are served.
# In production: https://YOUR-PROJECT.vercel.app/images
# Locally: leave empty (app returns the stored http://127.0.0.1:5000 URL)
IMAGE_BASE_URL=https://your-project.vercel.app/images

# ─── Optional ─────────────────────────────────────────────────────────────────

# Flask secret key — change to a random string in production
SECRET_KEY=change-me-to-a-random-secret-string
